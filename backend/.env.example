# IntellMeet API
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://nency:Intell123@cluster0.ljar5l7.mongodb.net/?appName=Cluster0

# JWT (generate strong random strings, e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m

# CORS — comma-separated list of allowed browser origins (must include your Vite URL)
# Example covers both common dev URLs:
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173

# Redis (optional: set REDIS_DISABLED=true to run without Redis)
REDIS_URL=redis://127.0.0.1:6379
REDIS_DISABLED=false
REDIS_MEETING_CACHE_TTL=120

# Rate limits (per IP, per window)
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_API_MAX=300

# Cloudinary (required for avatar + attachment uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Upload size cap (MB)
MAX_FILE_MB=10

